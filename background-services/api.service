[Unit]
Description=Deepfake FastAPI
After=network.target

[Service]
User=root
Group=root
WorkingDirectory=/var/www/html/core
Environment="PATH=/var/www/html/core/venv/bin"
ExecStart=/var/www/html/core/venv/bin/gunicorn \
  -k uvicorn.workers.UvicornWorker \
  -w 4 \
  -b 0.0.0.0:5000 \
  app.main:app 2>&1

Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target